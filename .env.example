# Vercel Blob — in Production/Preview erforderlich (Menü, Site-Content, Geschenk-Konfig, Bestellnr.).
# Ohne Token liest die App kein gebündeltes `data/*.json` aus dem Repo (veraltete Seed-/Stock-URLs).
# Optional: bei Blob-Lesefehler auf die im Deployment enthaltenen `data/*.json` zurückfallen (nur wenn dort aktuelle URLs stehen!)
# BLOB_READ_FALLBACK_TO_DISK=1
BLOB_READ_WRITE_TOKEN=

# Twilio Verify (SMS OTP for orders)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# HMAC secret for httpOnly cookie after successful SMS verify (min 32 random chars)
ORDER_PHONE_VERIFY_SECRET=

# Default region for parsing phone numbers (e.g. AT for Austria)
DEFAULT_PHONE_REGION=AT

# Order PDF recipient: ORDER_NOTIFY_EMAIL, else RESTAURANT_EMAIL, else sakebestellen@gmail.com
ORDER_NOTIFY_EMAIL=

# SMTP (required for order emails). Gmail example: host smtp.gmail.com, port 465, app password
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
RESTAURANT_EMAIL=

# Order PDF (Kassenbon, Thermodruck): Anzeigename, Telefon im Kopf, Öffnungszeiten & Liefertext Fuß
ORDER_PDF_RESTAURANT_NAME=Sake
RESTAURANT_PHONE=
# Platzhalter-URL für „Bild löschen“ im Admin (HTTPS, z. B. neutrales Bild in Cloudinary) — sonst Legacy-Fallback
# NEXT_PUBLIC_DISH_PLACEHOLDER_URL=

# Fortlaufende Bestellnr. (Blob `sake-vienna/order-sequence.json` oder lokal `data/order-sequence.json`)
# ORDER_SEQUENCE_INITIAL_LAST=0

# Telefonzeile unter Adresse im Kassen-PDF (Standard: 01 5223551)
# ORDER_PDF_HEADER_PHONE=
ORDER_PDF_OPENING_HOURS=Mi–Mo 11:00–21:30 Uhr · Di geschlossen
# ORDER_PDF_DELIVERY_DISTRICTS=   # optional, Standard: Bezirke 6,7,8,15,16
