# Twilio Verify (SMS OTP for orders)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# HMAC secret for httpOnly cookie after successful SMS verify (min 32 random chars)
ORDER_PHONE_VERIFY_SECRET=

# Default region for parsing phone numbers (e.g. AT for Austria)
DEFAULT_PHONE_REGION=AT

# Order PDF recipient: ORDER_NOTIFY_EMAIL, else RESTAURANT_EMAIL, else sakebestellen@gmail.com
ORDER_NOTIFY_EMAIL=

# SMTP (required for order emails). Gmail example: host smtp.gmail.com, port 465, app password
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
RESTAURANT_EMAIL=

# Order PDF (Kassenbon, Thermodruck): Anzeigename, Telefon im Kopf, Öffnungszeiten & Liefertext Fuß
ORDER_PDF_RESTAURANT_NAME=Sake
RESTAURANT_PHONE=
# ORDER_PDF_PHONE=   # Alternative zu RESTAURANT_PHONE
ORDER_PDF_OPENING_HOURS=Mo–So 11:00–22:00 Uhr · Dienstag Ruhetag
# ORDER_PDF_DELIVERY_DISTRICTS=   # optional, Standard: Bezirke 6,7,8,15,16
